{
  "name": "agentorg",
  "version": "0.1.0",
  "private": true,
  "description": "Run businesses that couldn't exist before — powered by AI agent teams",
  "keywords": ["ai", "agents", "orchestration", "multi-agent", "company", "automation"],
  "license": "Apache-2.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
